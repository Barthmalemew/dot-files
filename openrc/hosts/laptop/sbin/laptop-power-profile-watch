#!/bin/sh

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

interval="${1:-30}"
low_threshold="${2:-25}"
profile_path="/sys/firmware/acpi/platform_profile"
choices_path="/sys/firmware/acpi/platform_profile_choices"

has_choice() {
    [ -r "$choices_path" ] || return 1
    grep -qw "$1" "$choices_path"
}

supported_profile() {
    desired="$1"

    if has_choice "$desired"; then
        printf '%s\n' "$desired"
        return
    fi

    case "$desired" in
        low-power)
            if has_choice balanced; then
                printf '%s\n' balanced
            else
                printf '%s\n' "$desired"
            fi
            ;;
        performance)
            if has_choice performance; then
                printf '%s\n' performance
            elif has_choice balanced; then
                printf '%s\n' balanced
            else
                printf '%s\n' "$desired"
            fi
            ;;
        *)
            printf '%s\n' "$desired"
            ;;
    esac
}

ac_online() {
    for supply in /sys/class/power_supply/*; do
        [ -r "$supply/type" ] || continue
        read -r type < "$supply/type"

        case "$type" in
            Mains|USB|USB_C|USB_PD)
                [ -r "$supply/online" ] || continue
                read -r online < "$supply/online"
                [ "$online" = "1" ] && return 0
                ;;
        esac
    done

    return 1
}

battery_capacity() {
    for supply in /sys/class/power_supply/*; do
        [ -r "$supply/type" ] || continue
        read -r type < "$supply/type"
        [ "$type" = "Battery" ] || continue

        if [ -r "$supply/capacity" ]; then
            read -r capacity < "$supply/capacity"
            printf '%s\n' "$capacity"
            return
        fi
    done

    printf '\n'
}

desired_profile() {
    if ac_online; then
        printf '%s\n' performance
        return
    fi

    capacity="$(battery_capacity)"

    if [ -n "$capacity" ] && [ "$capacity" -lt "$low_threshold" ] 2>/dev/null; then
        printf '%s\n' low-power
    else
        printf '%s\n' balanced
    fi
}

while :; do
    if [ -w "$profile_path" ]; then
        desired="$(desired_profile)"
        profile="$(supported_profile "$desired")"
        current=""
        [ -r "$profile_path" ] && read -r current < "$profile_path"

        if [ -n "$profile" ] && [ "$profile" != "$current" ]; then
            printf '%s\n' "$profile" > "$profile_path" 2>/dev/null || true
        fi
    fi

    sleep "$interval"
done
