# ========== Compilation Optimization Flags ==========
COMMON_FLAGS="-march=native -O2 -pipe"
CFLAGS="${COMMON_FLAGS}"
CXXFLAGS="${COMMON_FLAGS}"
FCFLAGS="${COMMON_FLAGS}"
FFLAGS="${COMMON_FLAGS}"

# ========== Parallel Compilation Settings ==========
# 8 CPU cores / 32 GiB RAM. Increase cautiously if thermals stay stable.
MAKEOPTS="-j8 -l8"
EMERGE_DEFAULT_OPTS="--jobs=3 --load-average=8 --keep-going --with-bdeps=y"

# ========== Language & Localization ==========
LC_MESSAGES=C
L10N="en en-US"
LINGUAS="en en_US"

# ========== Desktop / Laptop USE Flags ==========
USE="-systemd udev elogind dbus policykit networkmanager bluetooth git wayland pipewire pulseaudio screencast vulkan vaapi acpi upower udisks"

# ========== Hardware Targets ==========
CPU_FLAGS_X86="aes avx avx2 bmi1 bmi2 f16c fma3 mmx mmxext pclmul popcnt rdrand sha sse sse2 sse3 sse4_1 sse4_2 ssse3 vpclmulqdq"
VIDEO_CARDS="intel"
INPUT_DEVICES="libinput"

# ========== License Configuration ==========
ACCEPT_LICENSE="*"

# ========== Build Behavior ==========
FEATURES="buildpkg binpkg-multi-instance parallel-fetch parallel-install"
LDFLAGS="-Wl,-O1 -Wl,--as-needed"
